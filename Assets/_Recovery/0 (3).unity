MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 63776708}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f03149e3c55bd4a4e8d0cef849ba709b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogueData
  npcName: "\u0421\u0442\u0430\u0440\u0438\u043A"
  npcRole: "\u0425\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C \u043E\u0434\u0438\u043D\u043E\u043A\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u0436\u043A\u0438 \u0443 \u0434\u0440\u0435\u0432\u043D\u0438\u0445
    \u0440\u0443\u0438\u043D"
  npcPersonality: "\u041C\u0443\u0434\u0440\u044B\u0439, \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u044B\u0439,
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439,
    \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u044B\u0439, \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0439"
  npcSpeechStyle: "\u0413\u043E\u0432\u043E\u0440\u0438\u0442 \u0440\u0430\u0437\u043C\u0435\u0440\u0435\u043D\u043D\u043E,
    \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u043C\u0438, \u0432\u0434\u0443\u043C\u0447\u0438\u0432\u044B\u043C\u0438
    \u0444\u0440\u0430\u0437\u0430\u043C\u0438; \u0438\u043D\u043E\u0433\u0434\u0430
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442 \u043E\u0431\u0440\u0430\u0437\u043D\u044B\u0435
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u0438 \u043D\u0430\u043C\u0435\u043A\u0438"
  npcBackstory: "\u041C\u043D\u043E\u0433\u043E \u043B\u0435\u0442 \u0436\u0438\u0432\u0435\u0442
    \u0440\u044F\u0434\u043E\u043C \u0441 \u0440\u0443\u0438\u043D\u0430\u043C\u0438
    \u0438 \u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A \u043B\u044E\u0434\u0438
    \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442 \u0441\u044E\u0434\u0430 \u0438\u0437
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u0441\u0442\u0432\u0430, \u0436\u0430\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438\u043B\u0438 \u0441\u0442\u0440\u0430\u0445\u0430"
  npcLocationContext: "\u0421\u0447\u0438\u0442\u0430\u0435\u0442 \u044D\u0442\u043E
    \u043C\u0435\u0441\u0442\u043E \u0432\u0430\u0436\u043D\u044B\u043C \u0438 \u043D\u0435
    \u043B\u044E\u0431\u0438\u0442, \u043A\u043E\u0433\u0434\u0430 \u043A \u0434\u0440\u0435\u0432\u043D\u0438\u043C
    \u0432\u0435\u0449\u0430\u043C \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043B\u0435\u0433\u043A\u043E\u043C\u044B\u0441\u043B\u0435\u043D\u043D\u043E"
  npcKnowledge: "\u0417\u043D\u0430\u0435\u0442 \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C,
    \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u0440\u0443\u0438\u043D, \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430 \u0438 \u0441\u043B\u0443\u0445\u0438
    \u043E \u043F\u0440\u043E\u0448\u043B\u043E\u043C \u044D\u0442\u043E\u0433\u043E
    \u043C\u0435\u0441\u0442\u0430"
  npcUnknowns: "\u041D\u0435 \u0437\u043D\u0430\u0435\u0442 \u043C\u044B\u0441\u043B\u0435\u0439
    \u0438\u0433\u0440\u043E\u043A\u0430, \u0441\u043E\u0431\u044B\u0442\u0438\u0439
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \u044D\u0442\u043E\u0439
    \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u0438 \u0432\u0435\u0449\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
    \u0441\u0430\u043C"
  npcMotivation: "\u0425\u043E\u0447\u0435\u0442 \u0432\u0435\u0440\u043D\u0443\u0442\u044C
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442 \u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u0445\u0440\u0443\u043F\u043A\u043E\u0435 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u044D\u0442\u043E\u0433\u043E \u043C\u0435\u0441\u0442\u0430"
  npcSecret: "\u0421\u043A\u0440\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442 \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u043D\u0438\u043C"
  npcAttitudeToPlayer: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A \u0438\u0433\u0440\u043E\u043A\u0443 \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E,
    \u043D\u043E \u043F\u0440\u0438 \u0443\u0432\u0430\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0438 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442
    \u0434\u043E\u0432\u0435\u0440\u044F\u0442\u044C \u0431\u043E\u043B\u044C\u0448\u0435"
  npcCurrentEmotionalState: "\u0421\u043F\u043E\u043A\u043E\u0435\u043D \u0438 \u0441\u043E\u0431\u0440\u0430\u043D,
    \u043D\u043E \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435 \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D
    \u0438\u0437-\u0437\u0430 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430"
  npcConversationTendency: "\u0413\u043E\u0432\u043E\u0440\u0438\u0442 \u043D\u0435\u0442\u043E\u0440\u043E\u043F\u043B\u0438\u0432\u043E,
    \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E \u0438 \u043D\u0435 \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
    \u0432\u0441\u0435\u0433\u043E \u0441\u0440\u0430\u0437\u0443, \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u044F
    \u043D\u0430\u043C\u0435\u043A\u0438 \u043F\u0440\u044F\u043C\u044B\u043C \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u044F\u043C"
  isQuestGiver: 1
  greetingMessage: "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439,
    \u043F\u0443\u0442\u043D\u0438\u043A."
  questData:
    questId: quest_find_artifact
    questName: "\u0414\u0440\u0435\u0432\u043D\u0438\u0439 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442"
    description: "\u041D\u0430\u0439\u0442\u0438 \u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u0442\u0438
      \u0434\u0440\u0435\u0432\u043D\u0438\u0439 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442"
    requiredItemId: artifact_01
