  m_Script: {fileID: 11500000, guid: f03149e3c55bd4a4e8d0cef849ba709b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogueData
  npcName: "\u041B\u0435\u044F"
  npcRole: "\u0422\u0440\u0430\u0432\u043D\u0438\u0446\u0430, \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u0446\u0430
    \u0441\u0442\u0430\u0440\u0438\u043A\u0430"
  npcPersonality: "\u0412\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F,
    \u043C\u044F\u0433\u043A\u0430\u044F, \u0440\u0430\u0441\u0441\u0443\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F,
    \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0442\u0440\u0435\u0432\u043E\u0436\u043D\u0430\u044F,
    \u043D\u043E \u043D\u0435 \u0442\u0440\u0443\u0441\u043B\u0438\u0432\u0430\u044F"
  npcSpeechStyle: "\u0413\u043E\u0432\u043E\u0440\u0438\u0442 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u0438 \u043C\u044F\u0433\u043A\u043E, \u043D\u043E \u0442\u043E\u0447\u043D\u0435\u0435
    \u0438 \u043F\u0440\u043E\u0449\u0435, \u0447\u0435\u043C \u0441\u0442\u0430\u0440\u0438\u043A;
    \u0440\u0435\u0434\u043A\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0437\u0430\u0433\u0430\u0434\u043A\u0430\u043C\u0438,
    \u0447\u0430\u0449\u0435 \u0432\u044B\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044F
    \u043F\u0440\u044F\u043C\u043E \u0438 \u043F\u043E \u0434\u0435\u043B\u0443"
  npcBackstory: "\u0412\u044B\u0440\u043E\u0441\u043B\u0430 \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0435\u043A\u0443
    \u0438 \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u0437\u043D\u0430\u043B\u0430
    \u044D\u0442\u0438 \u043C\u0435\u0441\u0442\u0430; \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C
    \u0441\u0442\u0430\u043B\u0430 \u043F\u043E\u043C\u043E\u0433\u0430\u0442\u044C
    \u0441\u0442\u0430\u0440\u0438\u043A\u0443 \u0438 \u0443\u0447\u0438\u0442\u044C\u0441\u044F
    \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u044C \u0442\u043E, \u0447\u0442\u043E
    \u0434\u0440\u0443\u0433\u0438\u0435 \u043D\u0435 \u0432\u0438\u0434\u044F\u0442"
  npcLocationContext: "\u0427\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0442 \u043B\u0435\u0441
    \u0438 \u0440\u0443\u0438\u043D\u044B \u043A\u0430\u043A \u0447\u0430\u0441\u0442\u044C
    \u0436\u0438\u0432\u043E\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430,
    \u043A \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u043D\u0443\u0436\u043D\u043E
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u044C\u0441\u044F \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  npcKnowledge: "\u0417\u043D\u0430\u0435\u0442 \u043B\u0435\u0441\u043D\u044B\u0435
    \u0442\u0440\u043E\u043F\u044B, \u043C\u0435\u0441\u0442\u043D\u044B\u0435 \u0441\u043B\u0443\u0445\u0438,
    \u0442\u0440\u0430\u0432\u044B, \u0441\u043B\u0435\u0434\u044B \u0447\u0443\u0436\u043E\u0433\u043E
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u043B\u044B\u0448\u0430\u043B\u0430 \u043E\u0442 \u0441\u0442\u0430\u0440\u0438\u043A\u0430"
  npcUnknowns: "\u041D\u0435 \u0437\u043D\u0430\u0435\u0442 \u0432\u0441\u0435\u0439
    \u043F\u0440\u0430\u0432\u0434\u044B \u043E \u043F\u0440\u043E\u0448\u043B\u043E\u043C
    \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430 \u0438 \u043D\u0435 \u0443\u0432\u0435\u0440\u0435\u043D\u0430,
    \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0435\u043D
    \u0441 \u043D\u0435\u0439 \u0441\u0430\u043C \u0441\u0442\u0430\u0440\u0438\u043A"
  npcMotivation: "\u0425\u043E\u0447\u0435\u0442, \u0447\u0442\u043E\u0431\u044B
    \u043E\u043F\u0430\u0441\u043D\u044B\u0435 \u0432\u0435\u0449\u0438 \u043D\u0435
    \u043D\u0430\u0440\u0443\u0448\u0438\u043B\u0438 \u0445\u0440\u0443\u043F\u043A\u043E\u0435
    \u0441\u043F\u043E\u043A\u043E\u0439\u0441\u0442\u0432\u0438\u0435 \u044D\u0442\u043E\u0433\u043E
    \u043C\u0435\u0441\u0442\u0430 \u0438 \u0447\u0442\u043E\u0431\u044B \u043B\u044E\u0434\u0438
    \u043D\u0435 \u043D\u0430\u0432\u043B\u0435\u043A\u043B\u0438 \u0431\u0435\u0434\u0443
    \u043F\u043E \u043D\u0435\u0437\u043D\u0430\u043D\u0438\u044E"
  npcSecret: "\u041F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0441\u0442\u0430\u0440\u0438\u043A \u0441\u0432\u044F\u0437\u0430\u043D
    \u0441 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u043E\u043C \u0433\u043B\u0443\u0431\u0436\u0435,
    \u0447\u0435\u043C \u0433\u043E\u0432\u043E\u0440\u0438\u0442, \u043D\u043E \u043F\u043E\u043A\u0430
    \u043D\u0435 \u0440\u0435\u0448\u0430\u0435\u0442\u0441\u044F \u0441\u043A\u0430\u0437\u0430\u0442\u044C
    \u043E\u0431 \u044D\u0442\u043E\u043C \u043F\u0440\u044F\u043C\u043E"
  npcAttitudeToPlayer: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D\u043D\u043E, \u043D\u043E
    \u0431\u044B\u0441\u0442\u0440\u0435\u0435 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442
    \u0434\u043E\u0432\u0435\u0440\u044F\u0442\u044C, \u0435\u0441\u043B\u0438 \u0438\u0433\u0440\u043E\u043A
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u0438 \u0431\u0435\u0437 \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0435\u0440\u0438\u044F"
  npcCurrentEmotionalState: "\u0421\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u043D\u0430\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D\u0430,
    \u0441\u0442\u0430\u0440\u0430\u0435\u0442\u0441\u044F \u043D\u0435 \u043F\u0443\u0433\u0430\u0442\u044C,
    \u043D\u043E \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0442, \u0447\u0442\u043E
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u0435\u0435,
    \u0447\u0435\u043C \u043A\u0430\u0436\u0435\u0442\u0441\u044F"
  npcConversationTendency: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E \u0438 \u043F\u0440\u0438\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043A \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A\u0443, \u043D\u043E
    \u043F\u0440\u0438 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E\u043C \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0435
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0431\u043E\u043B\u0435\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439 \u0438 \u043F\u0440\u044F\u043C\u043E\u0439"
  isQuestGiver: 0
  greetingMessage: "\u0422\u044B \u043D\u0435 \u043C\u0435\u0441\u0442\u043D\u044B\u0439,
    \u0434\u0430? \u0417\u0434\u0435\u0441\u044C \u0440\u0435\u0434\u043A\u043E \u043F\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0435 \u043B\u044E\u0434\u0438."
  questData:
    questId: quest_find_artifact
    questName: "\u0414\u0440\u0435\u0432\u043D\u0438\u0439 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442"
    description: "\u041D\u0430\u0439\u0442\u0438 \u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u0442\u0438
      \u0434\u0440\u0435\u0432\u043D\u0438\u0439 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442"
    requiredItemId: artifact_01
