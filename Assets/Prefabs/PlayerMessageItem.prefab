  m_text: "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439, \u043F\u0443\u0442\u043D\u0438\u043A.
    \u0412 \u0440\u0443\u0438\u043D\u0430\u0445 \u0445\u0440\u0430\u043D\u0438\u0442\u0441\u044F
    \u0434\u0440\u0435\u0432\u043D\u0438\u0439 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442.
    \u041E\u043D \u043C\u043E\u0436\u0435\u0442 \u043C\u043D\u043E\u0433\u043E\u0435
    \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C, \u043D\u043E \u0431\u0443\u0434\u044C
